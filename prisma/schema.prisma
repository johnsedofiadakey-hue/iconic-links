generator client {
  provider = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "postgresql"
}

model Organization {
  id        String   @id @default(uuid())
  name      String
  users     User[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model User {
  id             String        @id @default(uuid())
  phone          String?       @unique
  email          String?       @unique
  name           String?
  password       String?       // For staff login (NextAuth), customers use OTP
  role           Role          @default(CUSTOMER)
  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id])
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  customerProfile CustomerProfile?
  staffProfile    StaffProfile?
  orders          Order[]
  files           File[]
  consumptions    MaterialConsumption[]
  deliveries      Delivery[]
}

enum Role {
  SUPER_ADMIN
  MANAGER
  CUSTOMER_SERVICE
  PRODUCTION_WORKER
  QC_OFFICER
  DELIVERY_DRIVER
  CUSTOMER
}

model CustomerProfile {
  id         String   @id @default(uuid())
  userId     String   @unique
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  address    String?
  loyaltyPts Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model StaffProfile {
  id         String   @id @default(uuid())
  userId     String   @unique
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  branchId   String?
  branch     Branch?  @relation(fields: [branchId], references: [id], onDelete: SetNull)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([branchId])
}

model Branch {
  id        String   @id @default(uuid())
  name      String
  location  String
  staff     StaffProfile[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Category {
  id        String   @id @default(uuid())
  name      String
  imageUrl  String?
  services  Service[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum PricingType {
  INSTANT
  QUOTE_REQUIRED
}

model Service {
  id          String   @id @default(uuid())
  name        String
  description String?
  categoryId  String
  category    Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  pricingType PricingType @default(INSTANT)
  basePrice   Float?   // for INSTANT
  imageUrl    String?
  orderItems  OrderItem[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

enum OrderStatus {
  AWAITING_QUOTATION
  AWAITING_PAYMENT
  PREFLIGHT
  DESIGN_IN_PROGRESS
  AWAITING_APPROVAL
  PRINTING
  FINISHING
  QC_REJECTED
  READY_FOR_PICKUP
  OUT_FOR_DELIVERY
  COMPLETED
  CANCELLED
}

model Order {
  id          String   @id @default(uuid())
  orderNumber String   @unique
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  status      OrderStatus @default(AWAITING_PAYMENT)
  totalAmount Float    @default(0)
  items       OrderItem[]
  payments    Payment[]
  proofs      Proof[]
  consumptions MaterialConsumption[]
  delivery    Delivery?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId])
  @@index([status])
}

model OrderItem {
  id          String   @id @default(uuid())
  orderId     String
  order       Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  serviceId   String
  service     Service  @relation(fields: [serviceId], references: [id])
  quantity    Int      @default(1)
  price       Float    // Computed or quoted price
  specs       Json?    // Stores specific configurations (size, finish)
  files       File[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model File {
  id          String   @id @default(uuid())
  url         String
  fileName    String
  fileType    String
  fileSize    Int
  uploaderId  String
  uploader    User     @relation(fields: [uploaderId], references: [id])
  orderItemId String?
  orderItem   OrderItem? @relation(fields: [orderItemId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
}

model Payment {
  id            String   @id @default(uuid())
  orderId       String
  order         Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  amount        Float
  reference     String   @unique
  paystackRef   String?  @unique
  status        PaymentStatus @default(PENDING)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Proof {
  id          String   @id @default(uuid())
  orderId     String
  order       Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  fileUrl     String
  version     Int      @default(1)
  status      ProofStatus @default(PENDING)
  comments    String?
  approvedBy  String?  // user ID
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

enum ProofStatus {
  PENDING
  APPROVED
  REJECTED
}

model InventoryItem {
  id          String   @id @default(uuid())
  name        String
  unitType    String   // e.g., "Meters", "Sheets", "Units"
  quantity    Float    @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  consumptions MaterialConsumption[]
}

model MaterialConsumption {
  id              String   @id @default(uuid())
  inventoryItemId String
  inventoryItem   InventoryItem @relation(fields: [inventoryItemId], references: [id])
  orderId         String
  order           Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  quantityUsed    Float
  wastage         Float    @default(0)
  workerId        String?
  worker          User?    @relation(fields: [workerId], references: [id])
  createdAt       DateTime @default(now())

  @@index([orderId])
}

model Delivery {
  id          String   @id @default(uuid())
  orderId     String   @unique
  order       Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  address     String
  status      DeliveryStatus @default(PENDING)
  driverId    String?
  driver      User?    @relation(fields: [driverId], references: [id])
  proofUrl    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([driverId])
}

enum DeliveryStatus {
  PENDING
  DISPATCHED
  DELIVERED
  FAILED
}
