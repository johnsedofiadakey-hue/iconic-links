# ==========================================
# ICON LINKS - Environment Configuration
# ==========================================

# 1. Database (Prisma)
# Required for connecting to your external Postgres Database
# Ensure this uses the correct Postgres connection string
DATABASE_URL="postgresql://user:password@host:port/database"

# 2. NextAuth (Session Secret)
# Run `openssl rand -base64 32` to generate a secure string
NEXTAUTH_SECRET="your-super-secret-nextauth-string"
NEXTAUTH_URL="http://localhost:3000"

# 3. Paystack (Payments)
# Get these from your Paystack Dashboard (Settings > API Keys)
PAYSTACK_SECRET_KEY="sk_test_..."
NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY="pk_test_..."

# 3a. App Base URL (used for Paystack callback redirect after checkout)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# 4. Firebase App Hosting / Storage
# Note: App Hosting automatically provisions credentials for the default Firebase App,
# but if using Firebase Storage on the client side, you need your public config:
NEXT_PUBLIC_FIREBASE_API_KEY="AIzaSy..."
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN="icon-links.firebaseapp.com"
NEXT_PUBLIC_FIREBASE_PROJECT_ID="icon-links"
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET="icon-links.appspot.com"
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID="123456789"
NEXT_PUBLIC_FIREBASE_APP_ID="1:123:web:456"
